[Unit]
Description=ZufarMax backend
After=network.target postgresql.service

[Service]
Type=simple
WorkingDirectory=/opt/zufarmax/backend
ExecStart=/usr/bin/node src/main.js
Restart=always
RestartSec=5
Environment=NODE_ENV=production
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
